# ============================================================================
# Bokoma Store — Frontend env vars for Vercel
# ============================================================================
# Copie ces variables dans : Vercel → ton projet → Settings → Environment Variables
# (coche Production / Preview / Development selon le besoin)
# ============================================================================

# ─── API Backend ───────────────────────────────────────────────────────────
# En LOCAL  : http://localhost:5000/api/v1
# En PROD   : URL absolue de ton backend Railway → ex: https://bokoma-production.up.railway.app/api/v1
#
# ⚠️  Cette variable doit aussi être définie dans :
#     Vercel → Project → Settings → Environment Variables
#     (sinon le build Next.js embarquera la valeur par défaut = localhost:5000)
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_API_TIMEOUT=30000

# ─── Site ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Bokoma Store
NEXT_PUBLIC_APP_DESCRIPTION=La boutique en ligne de vêtements tendance pour hommes et femmes.

# ─── Cloudinary (images publiques — préfixe NEXT_PUBLIC_ requis) ───────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dfinmurky
# (clés serveur facultatives côté frontend, utiles seulement si upload signé)
CLOUDINARY_CLOUD_NAME=dfinmurky
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── Auth ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AUTH_HEADER=Authorization

# ─── Feature flags ─────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_REVIEWS=true
NEXT_PUBLIC_ENABLE_WISHLIST=true

# ─── Debug ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEBUG=false